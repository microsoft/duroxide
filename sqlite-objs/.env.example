# ─── SQLite-objs provider test configuration ───
#
# Copy this file to .env and adjust values as needed.
# .env is gitignored; .env.example is tracked.
#
# SQLITE_MODE controls which backend the test suite runs against.
# Valid values:
#   LOCAL_INMEM  — in-memory rusqlite (fast, default)
#   LOCAL_FILE   — local file via rusqlite (temp dir per test)
#   OBJS_AZURE   — Azure Blob Storage via sqlite-objs VFS
#
SQLITE_MODE=LOCAL_INMEM

# ─── Azure Storage settings (only needed for OBJS_AZURE) ───
#
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=duroxide-tests
